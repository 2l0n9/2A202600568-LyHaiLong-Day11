# .env.example
# Bạn cần đổi tên file này thành .env hoặc nhập các biến này vào Dashboard của Render

# 1. OpenAI API Key (Bắt buộc cho Embeddings và ChatGPT)
OPENAI_API_KEY="sk-proj-xxxxxx..."

# 2. Weaviate Cloud (Bắt buộc cho Vector Database)
WEAVIATE_URL="https://your-weaviate-cluster.weaviate.network"
WEAVIATE_API_KEY="your-weaviate-api-key"

# 3. Jina Reranker API (Bắt buộc để tránh dùng model nội bộ gây hết RAM)
JINA_API_KEY="jina_xxxxxx..."

# 4. Agent Key (Tùy chọn, FastAPI sẽ tự sinh nếu để trống)
AGENT_API_KEY="your-secret-api-key"
